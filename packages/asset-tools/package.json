{
  "name": "@asama/asset-tools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:placeholders": "tsx src/index.ts generate-placeholders",
    "generate:main2img": "tsx src/index.ts generate-main2img",
    "assets:generate:placeholder": "tsx src/index.ts assets:generate:placeholder",
    "assets:render:blender": "node --import tsx src/index.ts assets:render:blender",
    "assets:blender:calibration": "node --import tsx src/index.ts assets:blender:calibration",
    "assets:import:raster": "tsx src/index.ts assets:import:raster",
    "assets:postprocess": "tsx src/index.ts assets:postprocess",
    "assets:atlas": "tsx src/index.ts assets:atlas",
    "assets:validate": "tsx src/index.ts assets:validate",
    "assets:audit:production": "tsx src/index.ts assets:audit:production",
    "assets:generate:directional-wall-gates": "tsx src/generateDirectionalWallGates.ts",
    "assets:generate:building-scale-up": "tsx src/generateBuildingScaleUp.ts",
    "assets:generate:wide-surfaces": "tsx src/generateWideSurfaceBatch.ts",
    "assets:alignment:correct": "tsx src/correctIsometricAlignmentAssets.ts",
    "assets:alignment:correct-large-buildings": "tsx src/correctLargeBuildingFootprints.ts",
    "assets:alignment:contact-sheet": "tsx src/generateAlignmentContactSheet.ts",
    "assets:all": "tsx src/index.ts assets:all",
    "validate:manifest": "tsx src/index.ts validate-manifest",
    "validate:generated": "tsx src/index.ts validate-manifest generated",
    "clean": "tsx src/index.ts clean",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
