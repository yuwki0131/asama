{
  "name": "@asama/game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:server": "tsx src/server/index.ts",
    "build": "tsc -b && vite build",
    "test": "vitest run --passWithNoTests",
    "test:e2e:smoke": "vitest run --config vitest.e2e.config.ts e2e/smoke",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "tsc -b --noEmit",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@asama/content": "workspace:*",
    "@asama/shared": "workspace:*",
    "@asama/simulation": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "fastify": "^5.1.0",
    "pixi.js": "^8.6.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "playwright-core": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
